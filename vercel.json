{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/pages/login.html" },
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/pages/:path*", "destination": "/frontend/pages/:path*" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" }
  ]
}
